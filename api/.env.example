NODE_ENV=development
MONGODB_URI=
PORT=4000
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=info

# Resend — optional. If RESEND_API_KEY is unset, confirmation emails no-op silently.
RESEND_API_KEY=
EMAIL_FROM=OneCreations <hello@onecreations.in>

# Razorpay — all-or-nothing on the key pair. Leave both blank to disable /orders
# (returns 503 payments_unavailable). Webhook secret is independent; if unset the
# /webhooks/razorpay endpoint returns 503 webhook_unconfigured.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
